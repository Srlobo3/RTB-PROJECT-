function renderSkins() { const container = document.getElementById("skinsContainer"); if(!container) return; container.innerHTML = ""; skinsData.forEach(skin => { const card = document.createElement("div"); card.className = `skin-card border-${skin.rarity}`; let previewStyle = `background: ${skin.bg}; box-shadow: ${skin.shadow};`; if(skin.borderGlow) previewStyle += ` border: 2px solid ${skin.borderGlow};`; const isOwned = ownedSkins.includes(skin.id), isEquipped = equippedSkin === skin.id; let btnHtml = ""; if(isEquipped) btnHtml = `<button class="skin-btn btn-equipped">EQUIPADO</button>`; else if(isOwned) btnHtml = `<button class="skin-btn btn-equip" onclick="equipSkin('${skin.id}')">EQUIPAR</button>`; else btnHtml = `<button class="skin-btn btn-buy" onclick="buySkin('${skin.id}')">COMPRAR</button>`; let visualInside = skin.img ? `<img src="${skin.img}" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">` : skin.emoji; card.innerHTML = `<div class="skin-name">${skin.name}</div><div class="skin-preview" style="${previewStyle}">${visualInside}</div><div class="skin-mult">+${skin.mult.toFixed(1)}x Mult</div><div class="skin-info skin-price">${isOwned ? "Adquirido" : skin.price + " pts"}</div>${btnHtml}`; container.appendChild(card); }); }
