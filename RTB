function getEquippedItemStats() { if(!equippedItem) return { mult: 0, crit: 0, stealth: false, name: "Nenhum" }; const item = craftableItemsData.find(i => i.id === equippedItem); if(!item) return { mult: 0, crit: 0, stealth: false, name: "Nenhum" }; let s = { mult: 0, crit: 0, stealth: false, name: item.name }; if(item.type === "mult") s.mult = item.power; if(item.type === "crit") s.crit = item.power; if(item.type === "mult_crit") { s.mult = item.power; s.crit = item.critPower; } if(item.type === "mult_stealth") { s.mult = item.power; s.stealth = true; } return s; }
function updateEquippedItemVisual(visualId) { let visual = document.getElementById(visualId); if(!visual) return; if(equippedItem) { let item = craftableItemsData.find(i => i.id === equippedItem); visual.innerHTML = item ? item.icon : "💍"; visual.style.display = "block"; } else visual.style.display = "none"; }
function renderCraftingTab() { const namesTranslate = { desert_gem:"🏜️ Joia Deserto", sand_relic:"⏳ Relíquia Areia", wolf_fang:"🐺 Presa Lobo", ancient_bark:"🌲 Casca Anciã", demon_horn:"😈 Chifre Demônio", hell_fire:"🔥 Fogo Infernal", void_matter:"🌌 Matéria Vazio", cosmic_dust:"✨ Poeira Cósmica", dual_soul:"👼 Alma Dupla", divine_tears:"💧 Lágrima Divina" }; let matHTML = ""; for(let key in materials) matHTML += `<div>${namesTranslate[key] || key}: ${materials[key]}</div>`; document.getElementById("materialsList").innerHTML = matHTML; const container = document.getElementById("craftingListContainer"); container.innerHTML = ""; craftableItemsData.forEach(item => { const card = document.createElement("div"); card.className = "craft-card"; let costText = "", canCraft = true; for(let key in item.cost) { let userAmount = materials[key] || 0, req = item.cost[key]; if(userAmount < req) canCraft = false; costText += `${req}x ${namesTranslate[key] || key} | `; } const isOwned = craftedItems.includes(item.id), isEquipped = equippedItem === item.id; let btnHTML = ""; if(isEquipped) btnHTML = `<button class="craft-btn btn-c-equipped">EQUIPADO</button>`; else if(isOwned) btnHTML = `<button class="craft-btn btn-c-equip" onclick="equipCraftItem('${item.id}')">EQUIPAR</button>`; else btnHTML = `<button class="craft-btn btn-c-craft" onclick="craftItem('${item.id}')" ${!canCraft ? 'style="opacity:0.4;cursor:not-allowed;"' : ''}>CRIAR ITEM</button>`; card.innerHTML = `<h3>${item.icon} ${item.name}</h3><p>Efeito: ${item.desc}</p>${!isOwned ? `<div class="craft-cost">Custo: ${costText.slice(0,-3)}</div>` : `<div class="craft-cost" style="color:#00ff66;">Adquirido!</div>`}${btnHTML}`; container.appendChild(card); }); }
function craftItem(id) { const item = craftableItemsData.find(i => i.id === id); if(!item || craftedItems.includes(id)) return; for(let key in item.cost) if((materials[key] || 0) < item.cost[key]) return; for(let key in item.cost) materials[key] -= item.cost[key]; craftedItems.push(id); trackStat('totalCrafts', 1); renderCraftingTab(); updateRecordsUI(); }
function equipCraftItem(id) { if(!craftedItems.includes(id)) return; equippedItem = id; renderCraftingTab(); recalculateMultiplier(); updateScore(); updateInventoryText(); updateEquippedItemVisual("equippedItemVisual"); updateEquippedItemVisual("combatPlayerItemVisual"); }
function renderPotionsTab() { const namesTranslate = { desert_gem:"🏜️ Joia", sand_relic:"⏳ Relíquia", wolf_fang:"🐺 Presa", ancient_bark:"🌲 Casca", demon_horn:"😈 Chifre", hell_fire:"🔥 Fogo", void_matter:"🌌 Matéria", cosmic_dust:"✨ Poeira", dual_soul:"👼 Alma", divine_tears:"💧 Lágrima" }; const container = document.getElementById("potionsListContainer"); container.innerHTML = ""; potionsData.forEach(pot => { const card = document.createElement("div"); card.className = "craft-card"; let costText = "", canCraft = true; for(let key in pot.cost) { let userAmount = materials[key] || 0, req = pot.cost[key]; if(userAmount < req) canCraft = false; costText += `${req}x ${namesTranslate[key] || key} `; } card.innerHTML = `<h3 style="color:#00e5ff;">🧪 ${pot.name}</h3><p>${pot.desc}</p><div class="craft-cost">Requisitos: ${costText}</div><button class="craft-btn btn-c-craft" style="background:linear-gradient(45deg,#0088cc,#00e5ff);" onclick="craftAndUsePotion('${pot.id}')" ${!canCraft ? 'style="opacity:0.4;cursor:not-allowed;"' : ''}>FABRICAR E USAR</button>`; container.appendChild(card); }); }
function craftAndUsePotion(id) { const pot = potionsData.find(p => p.id === id); if(!pot) return; for(let key in pot.cost) if((materials[key] || 0) < pot.cost[key]) { alert("Materiais insuficientes!"); return; } for(let key in pot.cost) materials[key] -= pot.cost[key]; activeBuff.multiplier = pot.mult; activeBuff.duration = pot.duration; activeBuff.name = pot.name; trackStat('totalPotionsUsed', 1); alert(`Sucesso! Você consumiu a poção e ativou: ${pot.name}`); renderPotionsTab(); renderCraftingTab(); updateScore(); updateBuffDisplay(); updateRecordsUI(); }
function renderArtifactsTab() { const container = document.getElementById("artifactsListContainer"); if(!container) return; if(artifacts.length === 0) { container.innerHTML = "<p style='color:#ccc;'>Nenhum artefato encontrado. Complete Torres nas Dificuldades para ganhar!</p>"; return; } artifacts.forEach(art => { const isEquipped = equippedArtifacts.includes(art.uid); const card = document.createElement("div"); card.className = "craft-card"; card.innerHTML = `<h3 style="color:#ffd700;">${art.name}</h3><p>${art.effect}</p><button class="craft-btn ${isEquipped ? 'btn-c-equipped' : 'btn-c-equip'}" onclick="toggleArtifact('${art.uid}')">${isEquipped ? 'DESEQUIPAR' : 'EQUIPAR'}</button>`; container.appendChild(card); }); }
function toggleArtifact(uid) { if(equippedArtifacts.includes(uid)) equippedArtifacts = equippedArtifacts.filter(id => id !== uid); else { if(equippedArtifacts.length >= 3) { alert("Você só pode equipar 3 artefatos ao mesmo tempo!"); return; } equippedArtifacts.push(uid); } renderArtifactsTab(); updateInventoryText(); saveGame(); }
function dropArtifact() { let chance = towerDifficulty * 30; if(Math.random() * 100 <= chance) { let artTmpl = possibleArtifacts[Math.floor(Math.random() * possibleArtifacts.length)]; let newArtifact = { uid: "art_" + Date.now() + Math.floor(Math.random()*100), baseId: artTmpl.id, name: artTmpl.name, effect: artTmpl.effect, type: artTmpl.type, val: artTmpl.val }; artifacts.push(newArtifact); alert("🎁 VOCÊ OBTEVE UM ARTEFATO DE CHEFE!\nNome: " + newArtifact.name + "\nEfeito: " + newArtifact.effect); saveGame(); updateRecordsUI(); checkTitleUnlocks(); } }
function updateInventoryText() { const invText = document.getElementById("inventoryText"); let i_stats = getEquippedItemStats(); if(invText) invText.innerHTML = `<strong>Mapa Atual:</strong> ${mapsData[currentMap].name}<br><strong>Total de Rebirths:</strong> ${rebirthCount}<br><strong>Bônus Fixo Rebirth:</strong> +${(3.5 * rebirthCount).toFixed(1)}x Mult<br><strong>Skins Desbloqueadas:</strong> ${ownedSkins.length} de ${skinsData.length}<br><strong>Nível da História:</strong> ${ikaroDefeated ? "FASE EX" : storyLevel}<br><br><div style="background:#111;padding:10px;border-radius:10px;border:1px solid #444;color:#fff;"><h3 style="color:#00ff66;margin-top:0;">Item Ativo: ${i_stats.name}</h3>Bônus de Mult: +${i_stats.mult}x<br>Bônus de Crítico Clicks (Redução): -${i_stats.crit}<br>Bônus Furtividade: ${i_stats.stealth ? "Sim" : "Não"}</div>`; }
function switchInv(tab) { ["btnInvStats","btnInvCraft","btnInvPotions","btnInvArtifacts"].forEach(id => document.getElementById(id).classList.remove("active")); ["invStatsTab","invCraftTab","invPotionsTab","invArtifactsTab"].forEach(id => document.getElementById(id).style.display = "none"); if(tab === 'stats') { document.getElementById("btnInvStats").classList.add("active"); document.getElementById("invStatsTab").style.display = "block"; } else if(tab === 'craft') { document.getElementById("btnInvCraft").classList.add("active"); document.getElementById("invCraftTab").style.display = "block"; } else if(tab === 'potions') { document.getElementById("btnInvPotions").classList.add("active"); document.getElementById("invPotionsTab").style.display = "block"; } else { document.getElementById("btnInvArtifacts").classList.add("active"); document.getElementById("invArtifactsTab").style.display = "block"; } }

