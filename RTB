<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>StruBall - Jogo Incremental</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; }
body { margin: 0; overflow: hidden; background: #111; color: white; font-family: Arial, sans-serif; user-select: none; transition: 1s; -webkit-tap-highlight-color: transparent; touch-action: manipulation; }
.desertTheme { background: #3a2f15; color: #fff; }
.forestTheme { background: #0b1f0b; color: #fff; }
.hellTheme { background: #260505; color: #fff; }
.spaceTheme { background: #0a061c; color: #fff; }
.heavenHellTheme { background: linear-gradient(135deg, #051026 0%, #1a0202 100%); color: #fff; }
.mapEmoji { position: fixed; font-size: 45px; opacity: 0.14; pointer-events: none; z-index: 1; }
#menu, #modeScreen { position: fixed; inset: 0; display: flex; justify-content: center; align-items: center; flex-direction: column; background: radial-gradient(circle, #222, #000); z-index: 10000; padding: 20px; }
#menu h1 { font-size: clamp(36px, 10vw, 90px); font-family: 'Orbitron', sans-serif; color: #00aaff; text-shadow: 0 0 20px #00aaff, 0 0 50px #0080ff; text-align: center; line-height: 1.1; margin-bottom: 30px; }
.menuDecoration { position: absolute; font-size: clamp(30px, 8vw, 70px); opacity: 0.12; }
#menu button, #modeScreen button { padding: clamp(12px, 3vw, 20px) clamp(24px, 6vw, 60px); margin: 8px; border: none; border-radius: 18px; background: linear-gradient(45deg, #00aaff, #0055ff); color: white; font-size: clamp(18px, 4vw, 32px); cursor: pointer; transition: 0.2s; box-shadow: 0 0 20px #00aaff; width: min(340px, 90vw); }
#menu button:hover, #modeScreen button:hover { transform: scale(1.05); }
#modeScreen { display: none; z-index: 10001; }
#modeScreen h1 { font-family: 'Orbitron', sans-serif; font-size: clamp(24px, 6vw, 50px); text-align: center; margin-bottom: 20px; color: #fff; text-shadow: 0 0 15px #fff; }
#loading { position: fixed; inset: 0; background: radial-gradient(circle, #1a1a1a, #000); display: none; justify-content: center; align-items: center; flex-direction: column; z-index: 5000; }
#loading h1 { font-size: 55px; text-shadow: 0 0 15px #00aaff; }
#loadingBar { width: 420px; max-width: 90vw; height: 42px; background: #111; border-radius: 30px; overflow: hidden; margin-top: 25px; border: 3px solid #00aaff; box-shadow: 0 0 25px #00aaff, inset 0 0 15px #000; }
#loadingFill { width: 0%; height: 100%; background: linear-gradient(90deg, #00aaff, #00ffee, #00ff99, #00ffee, #00aaff); background-size: 300%; animation: loadingGlow 2s linear infinite; }
@keyframes loadingGlow { 0% { background-position: 0%; } 100% { background-position: 300%; } }
#gameUI { display: none; position: fixed; inset: 0; width: 100%; height: 100%; }
#score, #multiplierText, #activeBuffDisplay { width: 100%; text-align: center; z-index: 20; text-shadow: -1.5px -1.5px 0 #000, 1.5px -1.5px 0 #000, -1.5px 1.5px 0 #000, 1.5px 1.5px 0 #000, 0 0 8px #000; }
#score { position: absolute; top: 12px; font-size: clamp(18px, 4vw, 32px); font-weight: bold; }
#multiplierText { position: absolute; top: clamp(38px, 8vw, 55px); font-size: clamp(13px, 3vw, 22px); color: gold; }
#activeBuffDisplay { position: absolute; top: clamp(60px, 12vw, 90px); font-size: clamp(11px, 2.5vw, 18px); color: #00ff66; font-weight: bold; }
.ironSoulBadge { position: absolute; top: 12px; left: 12px; color: #ff3333; font-weight: bold; font-size: clamp(13px, 3vw, 20px); text-shadow: 0 0 10px #ff0000, -1px -1px 0 #000, 1px 1px 0 #000; z-index: 20; }
#ball { width: clamp(110px, 28vw, 160px); height: clamp(110px, 28vw, 160px); background: linear-gradient(145deg, #00aaff, #0055ff); border-radius: 50%; position: absolute; left: 50%; top: calc(50% - 40px); transform: translate(-50%, -50%); display: flex; justify-content: center; align-items: center; cursor: pointer; box-shadow: 0 0 40px #00aaff; z-index: 5; transition: transform 0.05s ease; }
#ball:active { transform: translate(-50%, calc(-50%)) scale(0.92); }
#rat { display: none; font-size: clamp(45px, 12vw, 75px); width:100%; height:100%; justify-content:center; align-items:center; }
#equippedItemVisual { display: none; position: absolute; top: 0px; right: 0px; font-size: 40px; pointer-events: none; z-index: 10; filter: drop-shadow(0 0 5px rgba(0,0,0,0.8)); }
#musicControls { position: fixed; top: 12px; right: 12px; z-index: 100; display: flex; gap: 8px; background: rgba(0,0,0,0.6); padding: 6px 10px; border-radius: 30px; backdrop-filter: blur(5px); }
.musicBtn { background: rgba(0,0,0,0.7); border: none; color: white; font-size: 20px; padding: 6px 12px; border-radius: 25px; cursor: pointer; transition: 0.2s; min-width: 44px; }
.musicBtn:hover { background: #00aaff; transform: scale(1.05); }
.musicBtn.mute { background: #ff3333; }
.gameButton { position: fixed; right: 16px; border: none; border-radius: 14px; padding: 12px 20px; font-size: 20px; cursor: pointer; background: #222; color: white; z-index: 50; transition: 0.2s; border: 1px solid #444; white-space: nowrap; }
.gameButton:hover { background: #333; }
#openAdventure { bottom: 390px; background: linear-gradient(45deg, #ff0055, #aa0000); box-shadow: 0 0 10px #ff0055; border:none; }
#openAdventure:hover { transform: scale(1.05); }
#openInventory { bottom: 315px; }
#openMap { bottom: 240px; }
#openRecords { bottom: 165px; background: linear-gradient(45deg, #6a0dad, #9b30ff); box-shadow: 0 0 10px #9b30ff; border:none; }
#openShop { bottom: 90px; }
#openAchievements { bottom: 15px; background: linear-gradient(45deg, #cc9900, #ffcc00); color: black; box-shadow: 0 0 10px #ffcc00; border:none; font-weight:bold; }
#resetButton { bottom: 15px; left: 16px; right: auto; background: linear-gradient(45deg, #550000, #990000); font-size: 14px; padding: 8px 14px; border:none; }
#resetButton:hover { background: linear-gradient(45deg, #770000, #cc0000); }
.popupMenu { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.96); z-index: 2500; display: none; justify-content: center; align-items: center; flex-direction: column; padding: 16px; overflow-y: auto; -webkit-overflow-scrolling: touch; }
.recordsContainer { background: #1a1a1a; border-radius: 20px; width: min(550px, 96vw); max-height: 92vh; overflow: hidden; display: flex; flex-direction: column; border: 1px solid #9b30ff; }
.recordsHeader { background: #111; padding: 15px; text-align: center; border-bottom: 2px solid #9b30ff; }
.recordsHeader h2 { margin: 0; color: #9b30ff; font-family: 'Orbitron', sans-serif; }
.recordsTabs { display: flex; flex-wrap: wrap; background: #222; padding: 8px; gap: 5px; border-bottom: 1px solid #444; }
.recordsTabBtn { padding: 10px 16px; background: #333; border: none; border-radius: 8px; color: #ccc; cursor: pointer; font-size: 14px; transition: 0.2s; }
.recordsTabBtn.active { background: #9b30ff; color: white; }
.recordsContent { flex: 1; overflow-y: auto; padding: 12px; max-height: 50vh; -webkit-overflow-scrolling: touch; }
.recordsContent .tabPane { display: none; }
.recordsContent .tabPane.active { display: block; }
.recordsCloseBtn { background: #aa0000; border: none; color: white; padding: 12px; font-size: 16px; cursor: pointer; width: 100%; border-radius: 0 0 20px 20px; transition: 0.2s; }
.recordsCloseBtn:hover { background: #ff0000; }
.statCard { background: #0d0d0d; border-radius: 10px; padding: 12px; margin-bottom: 8px; border-left: 4px solid #9b30ff; }
.statCard .statValue { font-size: 24px; font-weight: bold; color: #ffd700; }
.statCard .statLabel { color: #aaa; font-size: 12px; margin-top: 4px; }
.enemyCard, .materialCard, .titleCard { background: #0d0d0d; border-radius: 10px; padding: 10px 12px; margin-bottom: 8px; border-left: 3px solid #9b30ff; }
.enemyCard.locked, .materialCard.locked, .titleCard.locked { opacity: 0.6; filter: grayscale(0.3); border-left-color: #555; }
.enemyCard .enemyName { font-weight: bold; color: #ffcc00; }
.enemyCard.locked .enemyName:after { content: " ???"; color: #666; font-weight: normal; }
.titleCard .titleBadge { font-size: 18px; margin-right: 8px; }
#combatScreen, #storyScreen { display: none; z-index: 4000; flex-direction: column; background: rgba(0,0,0,0.98); overflow-y: auto; }
.combat-area { display: flex; justify-content: center; align-items: center; gap: clamp(12px, 4vw, 30px); width: 100%; margin-top: 16px; flex-wrap: wrap; }
.combat-entity { display: flex; flex-direction: column; align-items: center; min-width: 140px; }
.combat-ball { width: clamp(70px, 18vw, 110px); height: clamp(70px, 18vw, 110px); border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: clamp(28px, 7vw, 45px); box-shadow: 0 0 20px rgba(255,255,255,0.2); position:relative; }
.combat-health-bg { width: clamp(100px, 25vw, 150px); height: 16px; background: #333; border-radius: 10px; margin-top: 10px; overflow: hidden; border: 2px solid #555; }
.combat-health-fill { width: 100%; height: 100%; background: #00ff66; transition: 0.3s; }
.enemy-hp-fill { background: #ff3333; }
.combat-stats { margin-top: 10px; font-weight: bold; font-size: 16px; text-align: center; }
#combatLog { margin-top: 14px; width: 92%; max-width: 500px; height: clamp(70px, 15vh, 120px); background: #111; border: 1px solid #333; padding: 8px; overflow-y: auto; font-family: monospace; border-radius: 10px; font-size: 12px; -webkit-overflow-scrolling: touch; }
.attack-btn { margin-top: 14px; padding: clamp(10px, 3vw, 15px) clamp(20px, 5vw, 50px); font-size: clamp(18px, 4.5vw, 26px); font-weight: bold; border-radius: 15px; border: none; cursor: pointer; background: linear-gradient(45deg, #00aaff, #0055ff); color: white; box-shadow: 0 0 20px #00aaff; width: 92%; max-width: 340px; transition: 0.2s; min-height: 50px; }
.attack-btn:active { transform: scale(0.95); }
.flee-btn { margin-top: 10px; padding: 10px 30px; font-size: clamp(14px, 3.5vw, 18px); border-radius: 10px; border: none; background: #555; color: white; cursor: pointer; width: 92%; max-width: 200px; min-height: 44px; }
@keyframes atkPlayer { 0% { transform: translateX(0); } 50% { transform: translateX(40px); } 100% { transform: translateX(0); } }
@keyframes atkEnemy { 0% { transform: translateX(0); } 50% { transform: translateX(-40px); } 100% { transform: translateX(0); } }
@keyframes dmgShake { 0%, 100% { transform: translateX(0); filter: brightness(1); } 25% { transform: translateX(-8px) rotate(-10deg); filter: brightness(2) drop-shadow(0 0 15px red); } 75% { transform: translateX(8px) rotate(10deg); } }
@keyframes critShake { 0%, 100% { transform: translateX(0) scale(1); filter: brightness(1); } 20% { transform: translateX(-15px) scale(1.1); filter: brightness(3) sepia(1) hue-rotate(-50deg); } 80% { transform: translateX(15px) scale(1.1); } }
@keyframes dodgeAnim { 0%, 100% { transform: translateY(0); opacity:1; } 50% { transform: translateY(-35px); opacity:0.4; } }
@keyframes deathAnim { to { transform: scale(0) rotate(180deg); opacity: 0; filter: grayscale(1); } }
.anim-p-atk { animation: atkPlayer 0.3s ease-out; }
.anim-e-atk { animation: atkEnemy 0.3s ease-out; }
.anim-dmg { animation: dmgShake 0.3s ease-in-out; }
.anim-crit { animation: critShake 0.4s ease-in-out; }
.anim-dodge { animation: dodgeAnim 0.4s ease; }
.anim-death { animation: deathAnim 0.6s forwards ease-in; }
.dungeon-cell { width: clamp(44px, 11vw, 55px); height: clamp(44px, 11vw, 55px); border: 2px solid #444; border-radius: 8px; display: flex; justify-content: center; align-items: center; font-size: clamp(18px, 5vw, 25px); cursor: pointer; transition: 0.2s; background: #222; }
.dungeon-cell:hover { filter: brightness(1.5); transform: scale(1.05); }
#inventoryContent { background: #222; padding: clamp(14px, 3vw, 25px); border-radius: 20px; text-align: center; width: min(480px, 96vw); max-height: 92vh; overflow-y: auto; -webkit-overflow-scrolling: touch; }
.invTabBtns { display: flex; justify-content: center; margin-bottom: 14px; gap: 6px; flex-wrap: wrap; }
.invTabBtns button { padding: 9px 12px; background: #333; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: clamp(11px, 3vw, 14px); min-height: 40px; flex: 1; min-width: 60px; }
.invTabBtns button.active { background: #00aaff; font-weight: bold; }
.craft-card { background: #111; border: 1px solid #444; border-radius: 10px; padding: 15px; margin-bottom: 10px; text-align: left; }
.craft-card h3 { margin: 0 0 5px 0; color: #00ff66; font-size: 18px; }
.craft-card p { margin: 5px 0; font-size: 14px; color: #ccc; }
.craft-cost { color: gold; font-weight: bold; font-size: 13px; }
.craft-btn { width: 100%; padding: 8px; margin-top: 8px; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; }
.btn-c-craft { background: #00aaff; color: white; }
.btn-c-equip { background: #333; color: white; border: 1px solid #777; }
.btn-c-equipped { background: #00ff66; color: black; cursor: default; }
#inventoryContent button.closeBtn { margin-top: 20px; padding: 10px 30px; cursor: pointer; background: #aa0000; color: white; border: none; border-radius: 8px; }
#mapListContainer { max-height: 60vh; overflow-y: auto; width: 100%; display: flex; flex-direction: column; align-items: center; padding: 10px; }
.map-card { width: min(380px, 92vw); margin: 8px auto; padding: 16px 20px; border: none; border-radius: 18px; font-size: clamp(14px, 4vw, 20px); color: white; text-align: center; box-shadow: 0 0 15px rgba(255,255,255,0.1); opacity: 0.5; cursor: not-allowed; }
.map-unlocked { opacity: 1 !important; cursor: pointer !important; }
.map-unlocked:hover { transform: scale(1.03); }
.map-deserto { background: linear-gradient(45deg, #5c4a24, #8c7137); }
.map-floresta { background: linear-gradient(45deg, #1d4d1d, #2d7d2d); }
.map-inferno { background: linear-gradient(45deg, #4d0b0b, #8a1414); }
.map-espaco { background: linear-gradient(45deg, #150a3a, #2a1475); }
.map-heavenhell { background: linear-gradient(135deg, #0d1b3e 0%, #3e0d0d 100%); border: 2px solid #ffd700; box-shadow: 0 0 15px #ffd700; }
.mapCloseButton { margin-top: 16px; padding: 14px 36px; border: none; border-radius: 16px; background: linear-gradient(45deg, #aa0000, #ff3333); color: white; font-size: clamp(16px, 4vw, 22px); cursor: pointer; min-height: 50px; }
#shopMenu { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.97); z-index: 3000; display: none; }
#shopContainer { display: flex; width: 100%; height: 100%; flex-direction: column; }
#shopTabs { width: 100%; background: #111; display: flex; flex-direction: row; flex-wrap: wrap; padding: 10px; gap: 6px; overflow-y: visible; justify-content: center; }
.shopTab { flex: 1; min-width: 70px; padding: 12px 10px; margin: 0; border: none; border-radius: 12px; background: #222; color: white; font-size: clamp(13px, 3.5vw, 18px); cursor: pointer; transition: 0.2s; text-align: center; }
.shopTab.active { background: linear-gradient(45deg, #00aaff, #0055ff); }
#shopContent { flex: 1; display: flex; justify-content: flex-start; align-items: center; flex-direction: column; overflow-y: auto; padding: clamp(10px, 3vw, 20px); -webkit-overflow-scrolling: touch; }
.shopPage { display: none; width: 100%; text-align: center; }
.shopPage.active { display: block; }
.shopPage button { width: min(340px, 92vw); padding: clamp(12px, 3vw, 20px); margin: 8px auto; border: none; border-radius: 14px; font-size: clamp(16px, 4vw, 22px); cursor: pointer; display: block; min-height: 52px; }
.normalButton { background: #222; color: white; transition: 0.2s; }
.normalButton:hover { background: #333; }
.rebirthButton { background: linear-gradient(45deg, gold, orange); color: black; font-size: clamp(20px, 5vw, 28px); font-weight: bold; height: auto; padding: 20px !important; box-shadow: 0 0 25px gold; transition: 0.2s; }
.rebirthButton:hover { transform: scale(1.02); }
.clickEffect { position: fixed; color: white; font-size: clamp(20px, 5vw, 28px); font-weight: bold; pointer-events: none; z-index: 1000; animation: floatCursor 0.8s forwards; text-shadow: -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000; }
@keyframes floatCursor { from { opacity: 1; transform: translateY(0px); } to { opacity: 0; transform: translateY(-70px); } }
#criticalScreen { position: fixed; inset: 0; display: none; justify-content: center; align-items: center; flex-direction: column; z-index: 99998; pointer-events: none; }
#criticalScreen .criticalTitle { font-size: clamp(50px, 14vw, 90px); font-weight: bold; color: #00ff66; text-shadow: 0 0 20px #00ff66, 0 0 50px #00ff66, -2px -2px 0 #000, 2px 2px 0 #000; }
#criticalScreen .criticalGain { margin-top: 16px; font-size: clamp(26px, 7vw, 45px); color: white; text-shadow: 0 0 15px white, -2px -2px 0 #000, 2px 2px 0 #000; }
#foundScreen { position: fixed; inset: 0; background: black; z-index: 99999; display: none; justify-content: center; align-items: center; flex-direction: column; text-align: center; }
#foundScreen .skull { font-size: clamp(60px, 18vw, 120px); margin-bottom: 16px; }
#foundScreen .redText { color: red; font-size: clamp(28px, 8vw, 55px); font-weight: bold; margin-bottom: 16px; }
#foundScreen .whiteText { color: white; font-size: clamp(18px, 5vw, 32px); }
.skins-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; padding: 12px; max-height: 55vh; overflow-y: auto; width: 100%; -webkit-overflow-scrolling: touch; }
.skin-card { background: #161616; border-radius: 16px; padding: 12px; width: clamp(130px, 40vw, 165px); display: flex; flex-direction: column; align-items: center; text-align: center; box-sizing: border-box; position: relative; transition: transform 0.2s; }
.skin-card:hover { transform: scale(1.02); }
.border-comum { border: 2.5px solid #777777; }
.border-raro { border: 2.5px solid #00aaff; box-shadow: 0 0 10px rgba(0, 170, 255, 0.2); }
.border-epico { border: 2.5px solid #aa00ff; box-shadow: 0 0 12px rgba(170, 0, 255, 0.25); }
.border-lendario { border: 2.5px solid #ffd700; box-shadow: 0 0 15px rgba(255, 215, 0, 0.3); }
.border-mitico { border: 2.5px solid #ff0055; box-shadow: 0 0 20px rgba(255, 0, 85, 0.5); }
.skin-preview { width: 75px; height: 75px; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 38px; margin: 10px 0; overflow:hidden; }
.skin-name { font-weight: bold; font-size: 15px; color: #fff; }
.skin-mult { color: #00ff66 !important; font-weight: bold !important; font-size: 13px !important; margin-top: 4px !important; display: block !important; }
.skin-price { color: gold !important; font-weight: bold !important; font-size: 13px !important; margin: 4px 0 0 0 !important; display: block !important; }
.skin-btn { width: 120px !important; max-width: 100% !important; height: auto !important; padding: 8px 0 !important; margin: 10px auto 0 auto !important; display: block !important; border: none !important; border-radius: 8px !important; cursor: pointer !important; font-weight: bold !important; font-size: 12px !important; }
.btn-buy { background: linear-gradient(45deg, #0055ff, #00aaff); color: white; }
.btn-equip { background: #333; color: white; border: 1px solid #555; }
.btn-equipped { background: #00ff66; color: black; cursor: default; }
@media(max-width: 768px){
    #ball { top: calc(50% - 60px); }
    .gameButton { display: none !important; }
    #musicControls { top: auto; bottom: 80px; right: 12px; background: rgba(0,0,0,0.8); }
    .musicBtn { font-size: 16px; padding: 8px 12px; }
    #mobileNav {
        display: flex !important;
        position: fixed;
        bottom: 0; left: 0; right: 0;
        background: rgba(15,15,15,0.97);
        border-top: 1px solid #333;
        z-index: 100;
        padding: 6px 4px;
        padding-bottom: max(6px, env(safe-area-inset-bottom));
        gap: 2px;
        justify-content: space-around;
        align-items: stretch;
    }
    .mobileNavBtn {
        flex: 1;
        border: none;
        background: transparent;
        color: white;
        font-size: 18px;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 6px 2px;
        border-radius: 10px;
        transition: background 0.15s;
        min-width: 0;
        gap: 2px;
    }
    .mobileNavBtn span.nav-label {
        font-size: 9px;
        color: #aaa;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
    }
    .mobileNavBtn:active { background: rgba(255,255,255,0.1); }
    .mobileNavBtn.nav-adventure { color: #ff4477; }
    .mobileNavBtn.nav-shop { color: #00aaff; }
    .mobileNavBtn.nav-records { color: #9b30ff; }
    .mobileNavBtn.nav-achieve { color: #ffcc00; }
    #mobileMore {
        display: none;
        position: fixed;
        bottom: 70px; left: 0; right: 0;
        background: rgba(20,20,20,0.98);
        border-top: 1px solid #333;
        z-index: 99;
        padding: 10px;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
    }
    #mobileMore.open { display: flex; }
    .mobileMoreBtn {
        flex: 1;
        min-width: 100px;
        border: 1px solid #444;
        background: #222;
        color: white;
        border-radius: 10px;
        padding: 10px;
        font-size: 13px;
        cursor: pointer;
        text-align: center;
    }
    #mobileMoreResetBtn {
        background: linear-gradient(45deg,#550000,#990000);
        border-color: #880000;
    }
    #score { font-size: 17px; top: 10px; }
    #multiplierText { font-size: 13px; top: 34px; }
    #activeBuffDisplay { font-size: 11px; top: 55px; }
    #shopContainer { flex-direction: column; }
    #shopTabs { flex-direction: row; flex-wrap: wrap; gap: 5px; padding: 8px; }
    .shopTab { font-size: 12px; padding: 9px 6px; }
    #shopContent { padding: 10px; }
    .popupMenu { padding: 10px 8px; justify-content: flex-start; padding-top: 16px; }
    #inventoryContent { max-height: 88vh; padding: 14px 12px; width: 98vw; }
    .recordsContainer { width: 98vw; max-height: 88vh; }
    .recordsTabs { flex-wrap: wrap; gap: 4px; }
