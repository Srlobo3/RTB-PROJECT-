<script>
// ==================================================
// SISTEMA DE MÚSICA - CORRIGIDO
// ==================================================
let currentAudio = null;
let currentMusicType = "menu";
let musicVolume = 0.5;
let isMusicMuted = false;
let keepBattleMusic = false; // Controla se a música de batalha deve continuar

const battleMusicFiles = ["battle1.mp3", "battle2.mp3", "battle3.mp3"];

const musicFiles = {
    menu: "menu.mp3",
    desert: "desert.mp3",
    forest: "forest.mp3",
    hell: "hell.mp3",
    space: "space.mp3",
    heavenhell: "heavenhell.mp3",
    tower: "tower.mp3",
    story: "story.mp3"
};

function playRandomBattleMusic() {
    const randomIndex = Math.floor(Math.random() * battleMusicFiles.length);
    const selectedMusic = battleMusicFiles[randomIndex];
    
    if (currentAudio) {
        currentAudio.pause();
        currentAudio = null;
    }
    
    try {
        currentAudio = new Audio(selectedMusic);
        currentAudio.loop = true;
        currentAudio.volume = isMusicMuted ? 0 : musicVolume;
        currentAudio.play().catch(e => console.log("Auto-play bloqueado:", e));
        currentMusicType = "battle";
    } catch(e) {
        console.log("Erro ao carregar música de batalha:", e);
    }
}

function playMusic(type) {
    // Se estamos mantendo música de batalha e não é para parar, ignora
    if (keepBattleMusic && type !== "battle" && currentMusicType === "battle") {
        return;
    }
    
    // Se for batalha e já está tocando batalha, não faz nada
    if (type === "battle" && currentMusicType === "battle" && currentAudio && !currentAudio.paused) {
        return;
    }
    
    // Se for batalha, usa o sistema aleatório
    if (type === "battle") {
        playRandomBattleMusic();
        return;
    }
    
    if (currentMusicType === type && currentAudio && !currentAudio.paused) return;
    
    if (currentAudio) {
        currentAudio.pause();
        currentAudio = null;
    }
    
    const file = musicFiles[type];
    if (!file) return;
    
    try {
        currentAudio = new Audio(file);
        currentAudio.loop = true;
        currentAudio.volume = isMusicMuted ? 0 : musicVolume;
        currentAudio.play().catch(e => console.log("Auto-play bloqueado:", e));
        currentMusicType = type;
    } catch(e) {
        console.log("Erro ao carregar música:", e);
    }
}

function stopMusic() {
    if (currentAudio) {
        currentAudio.pause();
        currentAudio = null;
    }
    keepBattleMusic = false;
}

function toggleMusic() {
    isMusicMuted = !isMusicMuted;
    const btn = document.getElementById("playMusicBtn");
    if (currentAudio) {
        currentAudio.volume = isMusicMuted ? 0 : musicVolume;
    }
    if (btn) {
        btn.innerHTML = isMusicMuted ? "🔇" : "🔊";
        if (isMusicMuted) btn.classList.add("mute");
        else btn.classList.remove("mute");
    }
}

function volumeUp() {
    musicVolume = Math.min(1, musicVolume + 0.1);
    if (currentAudio && !isMusicMuted) currentAudio.volume = musicVolume;
}

function volumeDown() {
    musicVolume = Math.max(0, musicVolume - 0.1);
    if (currentAudio && !isMusicMuted) currentAudio.volume = musicVolume;
}

// ==================================================
// VARIÁVEIS PRINCIPAIS
// ==================================================
