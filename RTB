                document.getElementById("foundLossTitleText").innerText = ""; 
                document.getElementById("foundLossText").innerText = "ACABOU PRA VOCÊ"; 
                document.getElementById("foundScreen").style.display = "flex"; 
                setTimeout(() => window.location.reload(), 3500); 
            }, 1000); 
        } else { 
            setTimeout(() => { checkFoundEvent2(); fleeCombat(); }, 1000); 
        }
        // Quando perde, para a música de batalha e volta para a do mapa
        keepBattleMusic = false;
        playMusic(currentMap === "default" ? "menu" : mapsData[currentMap]?.music || "menu");
    } 
}
function advanceNextWave() { 
    infiniteWave++; 
    c_playerHp = c_playerMaxHp; 
    buildInfiniteWaveEnemy(); 
    document.getElementById("attackBtn").style.display = "block"; 
    document.getElementById("nextWaveBtn").style.display = "none"; 
    logCombat(`--- Iniciando Wave ${infiniteWave} ---`, "#00aaff"); 
    updateCombatUI(); 
    inCombat = true; 
    document.getElementById("combatEnemyBall").classList.remove("anim-death");
    // Música de batalha CONTINUA (keepBattleMusic continua true)
}
function advanceNextStoryWave() { 
    storySubWave++; 
    c_playerHp = c_playerMaxHp; 
    buildStoryEnemy(); 
    document.getElementById("attackBtn").style.display = "block"; 
    document.getElementById("nextWaveBtn").style.display = "none"; 
    logCombat(`--- O próximo inimigo se aproxima ---`, "#00aaff"); 
    updateCombatUI(); 
    inCombat = true; 
    document.getElementById("combatEnemyBall").classList.remove("anim-death");
    // Música de batalha CONTINUA no história também
}
function fleeCombat() { 
    inCombat = false; 
    toggleMenu('combatScreen', false); 
    keepBattleMusic = false;
    playMusic(currentMap === "default" ? "menu" : mapsData[currentMap]?.music || "menu");
}
function updateStoryUI() { let sLevelIdx = storyLevel - 1; if(ikaroDefeated) { storyLevel = 11; sLevelIdx = 10; document.getElementById("adventureStoryLevelText").innerText = `Fase EX`; document.getElementById("storyScreenTitle").innerText = `EX - O Desafio Supremo`; document.getElementById("storyTextDesc").innerText = storyData[sLevelIdx].text; } else { if(storyLevel > 10) storyLevel = 10; document.getElementById("adventureStoryLevelText").innerText = `Fase ${storyLevel}`; document.getElementById("storyScreenTitle").innerText = `${storyLevel} - A Jornada`; document.getElementById("storyTextDesc").innerText = storyData[sLevelIdx].text; } const currentSkinData = skinsData.find(s => s.id === equippedSkin) || skinsData[0]; const sPBall = document.getElementById("storyPlayerBall"); sPBall.style.background = currentSkinData.bg; sPBall.style.boxShadow = currentSkinData.shadow; if(currentSkinData.img) sPBall.innerHTML = `<img src="${currentSkinData.img}" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">`; else sPBall.innerHTML = currentSkinData.emoji; let eBall = document.getElementById("storyEnemyBall"); if(storyLevel === 10) { eBall.innerText = "👑"; eBall.style.background = "linear-gradient(45deg, #000, #ff0000)"; } else if(storyLevel === 11) { eBall.innerText = "🌀"; eBall.style.background = "linear-gradient(45deg, #ff8800, #ffff00)"; } else { eBall.innerText = "👹"; eBall.style.background = "#8a1414"; } }
function finishGame() { document.getElementById("endingScreen").style.display = "none"; document.getElementById("theEndScreen").style.display = "flex"; }
function returnToTitle() { document.getElementById("theEndScreen").style.display = "none"; ikaroDefeated = true; saveGame(); window.location.reload(); }
function resetGame(silent) { if(silent || confirm("⚠️ Tem certeza absoluta que deseja RESETAR tudo? Você perderá todos os seus pontos, melhorias, skins, artefatos, conquistas e mapas!")) { isResetting = true; clearInterval(autoSaveInterval); currentMap = "default"; localStorage.removeItem("RapeTheBallSave_V11"); window.location.reload(); } }

// ==================================================
// SAVE/LOAD
// ==================================================
function saveGame(){ if(isResetting) return; localStorage.setItem("RapeTheBallSave_V11", JSON.stringify({ points, multiplier, permanentMultiplier, multiplierPrice, critChance, critUpgradePrice, critUpgradeAmount, rebirthPrice, rebirthCount, totalClicks, currentMap, ownedSkins, equippedSkin, materials, craftedItems, equippedItem, activeBuff, p_forca, p_const, p_prec, p_agil, cost_forca, cost_const, cost_prec, cost_agil, storyLevel, ironSoulMode, achievements, artifacts, equippedArtifacts, ikaroDefeated, playerStats, discoveredEnemies, discoveredMaterials, unlockedTitles })); }
function loadGame(){ const save = localStorage.getItem("RapeTheBallSave_V11"); if(!save) { hasSave = false; applySkinVisual(skinsData[0]); renderSkins(); updateInventoryText(); updateButtonsText(); updateRecordsUI(); return; } hasSave = true; const data = JSON.parse(save); points = data.points || 0; permanentMultiplier = data.permanentMultiplier || 0; multiplierPrice = data.multiplierPrice || 1000; critChance = data.critChance || 10000; critUpgradePrice = data.critUpgradePrice || 500; critUpgradeAmount = data.critUpgradeAmount || 25; rebirthPrice = data.rebirthPrice || 100000; rebirthCount = data.rebirthCount || 0; totalClicks = data.totalClicks || 0; ironSoulMode = data.ironSoulMode || false; ikaroDefeated = data.ikaroDefeated || false; p_forca = data.p_forca || 0; p_const = data.p_const || 0; p_prec = data.p_prec || 0; p_agil = data.p_agil || 0; cost_forca = data.cost_forca || 500; cost_const = data.cost_const || 500; cost_prec = data.cost_prec || 10000; cost_agil = data.cost_agil || 10000; storyLevel = data.storyLevel || 1; currentMap = data.currentMap || "default"; ownedSkins = data.ownedSkins || ["default"]; equippedSkin = data.equippedSkin || "default"; achievements = data.achievements || []; artifacts = data.artifacts || []; equippedArtifacts = data.equippedArtifacts || []; let savedMats = data.materials || {}; for(let key in materials) materials[key] = savedMats[key] || 0; craftedItems = data.craftedItems || []; equippedItem = data.equippedItem || null; activeBuff = data.activeBuff || { multiplier: 1, duration: 0, name: "" }; playerStats = data.playerStats || { totalClicks:totalClicks, totalDamageDealt:0, totalDamageTaken:0, totalBossesKilled:0, totalEnemiesKilled:0, totalRebirths:rebirthCount, totalPotionsUsed:0, totalCrafts:0, highestInfiniteWave:0, highestTowerDifficulty:0, totalStruPointsEarned:points, totalMaterialsCollected:0, totalSkinsUnlocked:ownedSkins.length, totalCombats:0 }; discoveredEnemies = data.discoveredEnemies || []; discoveredMaterials = data.discoveredMaterials || []; unlockedTitles = data.unlockedTitles || []; const currentSkin = skinsData.find(s => s.id === equippedSkin) || skinsData[0]; currentSkinMult = currentSkin.mult; applySkinVisual(currentSkin); updateEquippedItemVisual("equippedItemVisual"); checkAutoMapUnlock(); recalculateMultiplier(); updateScore(); updateButtonsText(); renderSkins(); updateInventoryText(); updateBuffDisplay(); updateRecordsUI(); checkTitleUnlocks(); }
loadGame(); updateScore(); updateRecordsUI(); syncMobileNav();

setInterval(() => { if(activeBuff.duration > 0) { activeBuff.duration--; if(activeBuff.duration <= 0) { activeBuff.multiplier = 1; activeBuff.name = ""; alert("O efeito da sua poção alquímica expirou!"); recalculateMultiplier(); } updateScore(); updateBuffDisplay(); } }, 1000);
</script>
