function checkFoundEvent(){ if(totalClicks % 6000 !== 0) return; let itemStats = getEquippedItemStats(); let maxChance = itemStats.stealth ? 25 : 10; let chance = Math.floor(Math.random() * maxChance); if(chance !== 0) return; let lost = Math.floor(points * 0.35); points -= lost; document.getElementById("foundLossTitleText").innerText = "VOCÊ FOI ENCONTRADO!"; document.getElementById("foundLossText").innerText = "Você perdeu " + lost + " StruPoints"; document.getElementById("foundScreen").style.display = "flex"; setTimeout(() => document.getElementById("foundScreen").style.display = "none", 2000); updateScore(); }
function checkFoundEvent2(){ let lost = Math.floor(points * 0.35); points -= lost; document.getElementById("foundLossTitleText").innerText = "VOCÊ FOI ENCONTRADO!"; document.getElementById("foundLossText").innerText = "Você perdeu " + lost + " StruPoints"; document.getElementById("foundScreen").style.display = "flex"; setTimeout(() => document.getElementById("foundScreen").style.display = "none", 2000); updateScore(); }
function criticalHit(){ let itemStats = getEquippedItemStats(); let effectiveCritChance = Math.max(10, critChance - itemStats.crit); let random = Math.floor(Math.random() * effectiveCritChance); if(random === 0){ let gain = Math.floor(2500 * (multiplier * activeBuff.multiplier)); points += gain; document.getElementById("criticalGainText").innerText = "+ " + gain + " StruPoints"; let screen = document.getElementById("criticalScreen"); screen.style.display = "flex"; setTimeout(() => screen.style.display = "none", 700); } }
