function selectMap(mapId) { 
    const map = mapsData[mapId]; 
    if(!map) return; 
    if(rebirthCount < map.req) { 
        alert(`Você precisa de pelo menos ${map.req} Rebirths para acessar este mapa!`); 
        return; 
    } 
    currentMap = mapId; 
    applyThemeVisuals(); 
    recalculateMultiplier(); 
    updateButtonsText(); 
    updateScore(); 
    updateInventoryText();
    if(map.music) playMusic(map.music);
    keepBattleMusic = false;
}
function checkAutoMapUnlock() { 
    let bestAvailableMap = "default"; 
    if(rebirthCount >= 20) bestAvailableMap = "heavenhell"; 
    else if(rebirthCount >= 12) bestAvailableMap = "space"; 
    else if(rebirthCount >= 7) bestAvailableMap = "hell"; 
    else if(rebirthCount >= 3) bestAvailableMap = "forest"; 
    else if(rebirthCount >= 1) bestAvailableMap = "desert"; 
    if(currentMap === "default" && bestAvailableMap !== "default") currentMap = bestAvailableMap; 
    applyThemeVisuals(); 
    recalculateMultiplier(); 
    updateButtonsText();
    if(mapsData[currentMap]?.music) playMusic(mapsData[currentMap].music);
    keepBattleMusic = false;
}
function recalculateMultiplier() { multiplier = 1 + permanentMultiplier; if(mapsData[currentMap]) multiplier += mapsData[currentMap].mult; multiplier += currentSkinMult; let itemStats = getEquippedItemStats(); multiplier += itemStats.mult; }
function applyThemeVisuals(){ 
    document.querySelectorAll('.mapEmoji').forEach(e => e.remove()); 
    document.body.classList.remove("desertTheme","forestTheme","hellTheme","spaceTheme","heavenHellTheme"); 
    if(currentMap === "default") return; 
    const map = mapsData[currentMap]; 
    document.body.classList.add(map.class); 
    for(let i=0;i<20;i++){ 
        let emoji = document.createElement("div"); 
        emoji.className = "mapEmoji"; 
        emoji.innerText = Math.random() > 0.5 ? map.emoji1 : map.emoji2; 
        emoji.style.left = Math.random()*100 + "vw"; 
        emoji.style.top = Math.random()*100 + "vh"; 
        document.body.appendChild(emoji); 
    } 
}
