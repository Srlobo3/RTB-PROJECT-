function checkTitleUnlocks() {
    let combatCount = playerStats.totalEnemiesKilled + playerStats.totalBossesKilled;
    let conditions = { 
        combatCount, enemiesKilled: playerStats.totalEnemiesKilled, bossesKilled: playerStats.totalBossesKilled,
        rebirths: rebirthCount, skinsCount: ownedSkins.length, totalPoints: playerStats.totalStruPointsEarned,
        storyComplete: (ikaroDefeated || storyLevel > 10), towerHardComplete: playerStats.highestTowerDifficulty >= 3,
        ironSoulSurvivor: (ironSoulMode && rebirthCount >= 12),
        totalClicks: playerStats.totalClicks,
        crafts: playerStats.totalCrafts,
        potionsUsed: playerStats.totalPotionsUsed,
        infiniteWave: playerStats.highestInfiniteWave,
        artifactsCount: artifacts.length
    };
    for(let title of titlesDatabase) if(!unlockedTitles.includes(title.id) && titleConditions[title.id] && titleConditions[title.id](conditions)) { unlockedTitles.push(title.id); console.log(`🏅 Título desbloqueado: ${title.name}`); }
    updateRecordsUI();
}

