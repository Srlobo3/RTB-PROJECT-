function buyCritUpgrade(){ if(points < critUpgradePrice) return; points -= critUpgradePrice; critChance -= critUpgradeAmount; if(critChance < 10) critChance = 10; critUpgradeAmount += 25; critUpgradePrice = Math.floor(critUpgradePrice * 1.5); updateButtonsText(); updateScore(); }
function buyRandomColor(){ if(points < 2000) return; points -= 2000; let colors = ["red","blue","green","purple","gold","pink","cyan"]; let color = colors[Math.floor(Math.random()*colors.length)]; let ballEl = document.getElementById("ball"); ballEl.style.background = color; ballEl.style.boxShadow = "0 0 40px " + color; updateScore(); }
